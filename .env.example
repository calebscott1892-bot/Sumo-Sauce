# ─────────────────────────────────────────────────────
# SumoWatch — Environment Variables
# Copy this file to .env and fill in production values.
# ─────────────────────────────────────────────────────

# Base URL for the API backend.
# In development this is proxied by Vite; in production set to the backend URL.
# Default (when unset): /api
VITE_API_BASE_URL=/api

# Public-facing site URL (used for sitemap generation and canonical URLs).
# Default: https://sumowatch.app
SITE_URL=https://sumowatch.app

# ─── Server (backend) ───────────────────────────────

# Port for the Express API server.
PORT=8790

# Admin token for ingestion endpoints (POST /api/v1/admin/*).
# IMPORTANT: Change this in production!
ADMIN_TOKEN=change-me-in-production

# Database URL (Prisma/SQLite). Relative to server/ directory.
DATABASE_URL=file:./prisma/sumo.db
