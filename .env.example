# -----------------------------------------------------
# Sumo Sauce - Environment Variables
# Copy this file to .env and fill in production values.
# -----------------------------------------------------

# Base URL for the API backend.
# Set this in production to the public backend API origin, including the `/api` path.
# Local localhost development can leave this unset and use the Vite `/api` proxy instead.
# Example: https://your-render-service.onrender.com/api
VITE_API_BASE_URL=

# Public-facing site URL used for sitemap generation.
# Default: https://sumosauce.app
SITE_URL=https://sumosauce.app

# -------------------- Server (backend) --------------------

# Port for the Express API server.
PORT=8790

# Optional listen host for hosted Node services.
HOST=0.0.0.0

# Admin token for ingestion endpoints.
# IMPORTANT: Change this in production.
ADMIN_TOKEN=change-me-in-production

# Comma-separated origins allowed to call the API from browsers.
# Needed when the frontend and backend are on different origins.
# Example: https://sumosauce.app,https://sumo-sauce-git-main-yourteam.vercel.app
CORS_ALLOWED_ORIGINS=

# Database URL (Prisma/SQLite).
# Relative SQLite paths are resolved from server/prisma/schema.prisma.
# Local example: file:./sumo.db
# Render persistent disk example: file:/var/data/sumo.db
DATABASE_URL=file:./sumo.db
